{
  "cleanUrls": true,
  "functions": {
    "api/confirm-payment.js": {
      "maxDuration": 30
    },
    "api/portone-webhook.js": {
      "maxDuration": 30
    },
    "api/portone-diagnostics.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
